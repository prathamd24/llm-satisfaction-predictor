# ──────────────────────────────────────────────────────────────────────────────
# .env.example — LLM Satisfaction Predictor
# Copy to .env and set your values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# Path to the raw LLM usage dataset CSV
DATA_PATH=data/raw/genai_llm_usage_dataset_1000.csv

# FastAPI backend URL (used by Streamlit frontend)
BACKEND_URL=http://localhost:8000

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
